# ==== 通用基础配置 ====
POSTGRES_PASSWORD=replace_with_secure_db_password
REDIS_PASSWORD=replace_with_secure_redis_password
JWT_SECRET=replace_with_random_string_32_chars
TOTP_ENCRYPTION_KEY=replace_with_random_string_32_chars

# ==== Sub2API (核心网关) 配置 ====
ADMIN_EMAIL=admin@zerohongdie.com
ADMIN_PASSWORD=admin123456
SUB2API_PORT=8080

# ==== Sub2ApiPay (收银台) 配置 ====
PAY_PORT=3001
# Sub2ApiPay 管理后台的访问密码
PAY_ADMIN_TOKEN=your_secure_admin_token
# sub2apipay 需要调用 sub2api 的接口，请在此填入 Sub2API 管理后台生成的 API Key
SUB2API_ADMIN_API_KEY=replace_this_after_sub2api_setup
# 您的收银台对外的访问公网地址 (必填，用于回调)
NEXT_PUBLIC_APP_URL=https://pay.zerohongdie.com

# 启用的支付提供商 (支付宝官方直连,微信官方直连)
PAYMENT_PROVIDERS=alipay,wxpay
PRODUCT_NAME=Zero紅碟 Token 充值
PAY_HELP_TEXT=欢迎使用 Zero紅碟 Token 平台。\n如充值未到账，请联系客服微信。
PAY_HELP_IMAGE_URL=

# ==== 支付宝官方直连配置 ====
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ==== 微信支付官方直连配置 ====
WXPAY_APP_ID=
WXPAY_MCH_ID=
WXPAY_PRIVATE_KEY=
WXPAY_CERT_SERIAL=
WXPAY_API_V3_KEY=
WXPAY_PUBLIC_KEY_ID=
